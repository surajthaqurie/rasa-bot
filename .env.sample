# Rasa Chatbot - Environment Variables Template

# Log Level (Production: WARNING/ERROR, Dev: DEBUG/INFO)
LOG_LEVEL=INFO

# Rasa Server & Authentication
RASA_URL="http://localhost:5005"
RASA_TOKEN=your_secure_api_token_here

# Action Server (Optional)
ACTION_SERVER_URL=http://action-server:5055/webhook

# MongoDB (Tracker Store)
MONGO_URL="mongodb://rasa-mongo:27017"
MONGO_DB="rasa"
MONGO_USERNAME="rasabot"
MONGO_PASSWORD="your_secure_password"
MONGO_AUTH_SOURCE=admin
MONGO_COLLECTION="conversations"